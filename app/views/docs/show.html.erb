<% content_for :title, "Relative Timestamp Element for Rails + Stimulus" %>

<% now = Time.current %>
<% english_samples = [
  ["Now", now], ["30 sec", 30.seconds.ago], ["5 min", 5.minutes.ago], ["45 min", 45.minutes.ago],
  ["2 hr", 2.hours.ago], ["1 day", 1.day.ago], ["7 days", 7.days.ago], ["22 days", 22.days.ago],
  ["1 month", 30.days.ago], ["3 months", 90.days.ago], ["1 year", 365.days.ago], ["2 years", 730.days.ago]
] %>
<% spanish_samples = [
  ["Ahora", now], ["30 seg", 30.seconds.ago], ["5 min", 5.minutes.ago], ["45 min", 45.minutes.ago],
  ["2 h", 2.hours.ago], ["1 día", 1.day.ago], ["7 días", 7.days.ago], ["22 días", 22.days.ago],
  ["1 mes", 30.days.ago], ["3 meses", 90.days.ago], ["1 año", 365.days.ago], ["2 años", 730.days.ago]
] %>

