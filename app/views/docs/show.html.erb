    <section class="mx-auto grid max-w-7xl gap-12 px-5 pb-20 pt-10 sm:px-6 sm:pb-28 lg:grid-cols-[1.08fr_0.92fr] lg:px-8 lg:pt-16">
      <div>
        <p class="inline-flex rounded-full bg-[var(--ht-banana)] px-5 py-2 text-sm font-semibold text-[var(--ht-night)]">
          Hellotext plugin · Rails 8.1 · Importmap · Stimulus
        </p>
        <h1 class="font-display mt-8 max-w-4xl text-5xl font-semibold leading-[0.94] tracking-[-0.055em] text-white sm:text-7xl lg:text-8xl">
          Relative timestamps that keep selling in real time.
        </h1>
        <p class="mt-7 max-w-2xl text-lg leading-8 text-white/78 sm:text-xl">
          A production-ready Hellotext plugin sample that installs <code class="rounded-md bg-white/12 px-1.5 py-0.5 text-white">relative-timestamp-element</code>, wraps it in Stimulus, and documents the Rails integration with live fallback-first examples.
        </p>
        <div class="mt-9 flex flex-col gap-3 sm:flex-row">
          <a href="#install" class="inline-flex min-h-11 items-center justify-center rounded-full bg-[var(--ht-tiger)] px-6 py-3 text-sm font-semibold text-white transition-colors duration-200 hover:bg-[#db4000] focus:outline-none focus:ring-4 focus:ring-[var(--ht-tiger-20)]">
            Install the element
          </a>
          <a href="#sandbox" class="inline-flex min-h-11 items-center justify-center rounded-full border border-[var(--ht-seafoam)] bg-[var(--ht-seafoam)] px-6 py-3 text-sm font-semibold text-[var(--ht-night)] transition-colors duration-200 hover:bg-white focus:outline-none focus:ring-4 focus:ring-[var(--ht-seafoam)]/50">
            Open scale sandbox
          </a>
        </div>
      </div>

      <aside class="rounded-[2.25rem] bg-[var(--ht-seafoam)] p-4 text-[var(--ht-night)] shadow-[0_24px_80px_rgba(0,0,0,0.22)]">
        <div class="rounded-[1.75rem] bg-white p-6">
          <div class="flex items-center justify-between">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[var(--ht-indigo)]">Live browser label</p>
            <span class="inline-flex items-center gap-1.5 rounded-full bg-[var(--ht-seafoam-20)] px-3 py-1">
              <span class="relative flex h-2 w-2">
                <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[var(--ht-seafoam)] opacity-75" style="animation-duration: 1.5s"></span>
                <span class="relative inline-flex h-2 w-2 rounded-full bg-[var(--ht-seafoam)]"></span>
              </span>
              <span class="text-xs font-semibold uppercase tracking-wide text-[var(--ht-night)]">Live</span>
            </span>
          </div>

          <div class="mt-5 space-y-3">
            <div class="flex items-center gap-4 rounded-[1.25rem] bg-[var(--ht-lavender-light)] p-4" style="border-left: 4px solid var(--ht-indigo)">
              <div class="min-w-0 flex-1">
                <p class="truncate text-sm font-medium text-[var(--ht-night)]">Customer conversation updated</p>
                <p class="mt-0.5 text-xs text-[var(--ht-night-60)]">Support · Inbox</p>
              </div>
              <%= relative_timestamp_tag(30.seconds.ago, fallback: "30 sec", locale: "en", classes: "font-display shrink-0 text-2xl font-semibold tracking-[-0.04em] text-[var(--ht-indigo)]") %>
            </div>

            <div class="flex items-center gap-4 rounded-[1.25rem] bg-[var(--ht-banana-20)] p-4" style="border-left: 4px solid var(--ht-banana)">
              <div class="min-w-0 flex-1">
                <p class="truncate text-sm font-medium text-[var(--ht-night)]">New order received #4821</p>
                <p class="mt-0.5 text-xs text-[var(--ht-night-60)]">E‑commerce · Orders</p>
              </div>
              <%= relative_timestamp_tag(12.minutes.ago, fallback: "12 min", locale: "en", classes: "font-display shrink-0 text-2xl font-semibold tracking-[-0.04em] text-[var(--ht-night)]") %>
            </div>

            <div class="flex items-center gap-4 rounded-[1.25rem] bg-[var(--ht-blush-40)] p-4" style="border-left: 4px solid var(--ht-blush)">
              <div class="min-w-0 flex-1">
                <p class="truncate text-sm font-medium text-[var(--ht-night)]">Campaign "Summer Sale" sent</p>
                <p class="mt-0.5 text-xs text-[var(--ht-night-60)]">Marketing · Campaigns</p>
              </div>
              <%= relative_timestamp_tag(3.hours.ago, fallback: "3 hr", locale: "en", classes: "font-display shrink-0 text-2xl font-semibold tracking-[-0.04em] text-[var(--ht-night)]") %>
            </div>

            <div class="flex items-center gap-4 rounded-[1.25rem] bg-[var(--ht-seafoam-20)] p-4" style="border-left: 4px solid var(--ht-seafoam)">
              <div class="min-w-0 flex-1">
                <p class="truncate text-sm font-medium text-[var(--ht-night)]">Contact profile enriched</p>
                <p class="mt-0.5 text-xs text-[var(--ht-night-60)]">CRM · Contacts</p>
              </div>
              <%= relative_timestamp_tag(2.days.ago, fallback: "2 days", locale: "en", classes: "font-display shrink-0 text-2xl font-semibold tracking-[-0.04em] text-[var(--ht-night)]") %>
            </div>
          </div>
        </div>
      </aside>
    </section>
  </header>

  <main>

    <section id="sandbox" class="mx-auto max-w-7xl px-5 py-8 sm:px-6 lg:px-8">
      <div class="rounded-[2.5rem] bg-[var(--ht-night)] p-5 text-white sm:p-8" data-controller="timestamp-sandbox">
        <div class="grid gap-5 lg:grid-cols-[0.95fr_1.05fr] lg:items-end">
          <div class="max-w-2xl">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[var(--ht-seafoam)]">Real-time sandbox</p>
            <h2 class="font-display mt-2 text-4xl font-semibold tracking-[-0.045em] sm:text-5xl">Try it live with generated timestamps</h2>
            <p class="mt-4 leading-7 text-white/75">
              Pick a scenario, generate timestamp cards, and watch the Stimulus controller keep them fresh locally.
            </p>
          </div>

          <div class="rounded-[1.5rem] bg-white/10 p-3 text-sm text-white/80">
            <p><span class="font-semibold text-white" data-timestamp-sandbox-target="activeMetric">0</span> active cards</p>
            <p class="mt-1">Three simple batch examples and one custom timestamp test.</p>
          </div>
        </div>

        <div class="mt-6 rounded-[2rem] bg-white p-4 text-[var(--ht-night)] sm:p-5">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--ht-indigo)]">Pick a quick scenario</p>
          <div class="mt-4 grid gap-3 lg:grid-cols-3">
            <button type="button" class="min-h-28 cursor-pointer rounded-[1.5rem] bg-[var(--ht-seafoam)] p-5 text-left transition-colors duration-200 hover:bg-[var(--ht-banana)] focus:outline-none focus:ring-4 focus:ring-[var(--ht-indigo-20)]" data-action="timestamp-sandbox#runMixedBatch"><span class="font-display block text-2xl font-semibold tracking-[-0.035em]">Run basic batch</span><span class="mt-2 block text-sm leading-6 text-[var(--ht-night)]/75">10 mixed English and Spanish timestamps.</span></button>
            <button type="button" class="min-h-28 cursor-pointer rounded-[1.5rem] bg-[var(--ht-banana)] p-5 text-left transition-colors duration-200 hover:bg-[var(--ht-seafoam)] focus:outline-none focus:ring-4 focus:ring-[var(--ht-indigo-20)]" data-action="timestamp-sandbox#runEnglishBatch"><span class="font-display block text-2xl font-semibold tracking-[-0.035em]">Run English batch</span><span class="mt-2 block text-sm leading-6 text-[var(--ht-night)]/75">10 English timestamps with fixed sample ages.</span></button>
            <button type="button" class="min-h-28 cursor-pointer rounded-[1.5rem] bg-[var(--ht-blush)] p-5 text-left transition-colors duration-200 hover:bg-[var(--ht-banana)] focus:outline-none focus:ring-4 focus:ring-[var(--ht-indigo-20)]" data-action="timestamp-sandbox#runSpanishBatch"><span class="font-display block text-2xl font-semibold tracking-[-0.035em]">Run Spanish batch</span><span class="mt-2 block text-sm leading-6 text-[var(--ht-night)]/75">10 Spanish timestamps with fixed sample ages.</span></button>
          </div>
        </div>

        <div class="mt-5 grid gap-5 lg:grid-cols-[20rem_1fr]">
          <aside class="rounded-[2rem] bg-white p-5 text-[var(--ht-night)]">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--ht-indigo)]">Custom timestamp</p>
            <p class="mt-2 text-sm leading-6 text-[var(--ht-night-60)]">Test one exact date and locale.</p>
            <form class="mt-4 grid gap-4" aria-label="Custom timestamp controls">
              <label class="block"><span class="text-sm font-semibold">Locale</span><select class="mt-2 min-h-11 w-full rounded-xl border border-[var(--ht-night-10)] bg-white px-3 text-base focus:outline-none focus:ring-4 focus:ring-[var(--ht-indigo-20)]" data-timestamp-sandbox-target="customLocale"><option value="en">English</option><option value="es">Spanish</option></select></label>
              <label class="block"><span class="text-sm font-semibold">Date and time</span><input type="datetime-local" class="mt-2 min-h-11 w-full rounded-xl border border-[var(--ht-night-10)] bg-white px-3 text-base focus:outline-none focus:ring-4 focus:ring-[var(--ht-indigo-20)]" data-timestamp-sandbox-target="customDatetime"></label>
              <button type="button" class="min-h-11 cursor-pointer rounded-full bg-[var(--ht-tiger)] px-5 py-3 text-sm font-semibold text-white transition-colors duration-200 hover:bg-[#db4000] focus:outline-none focus:ring-4 focus:ring-[var(--ht-tiger-20)]" data-action="timestamp-sandbox#addCustom">Add custom timestamp</button>
              <button type="button" class="min-h-11 cursor-pointer rounded-full bg-[var(--ht-seafoam)] px-5 py-3 text-sm font-semibold text-[var(--ht-night)] transition-colors duration-200 hover:bg-[var(--ht-banana)] focus:outline-none focus:ring-4 focus:ring-[var(--ht-indigo-20)]" data-action="timestamp-sandbox#setNow">Set to Now</button>
              <button type="button" class="min-h-11 cursor-pointer rounded-full border border-[var(--ht-night-10)] px-5 py-3 text-sm font-semibold transition-colors duration-200 hover:bg-[var(--ht-night)] hover:text-white focus:outline-none focus:ring-4 focus:ring-[var(--ht-indigo-20)]" data-action="timestamp-sandbox#clear">Clear sandbox</button>
            </form>
          </aside>

          <div class="rounded-[2rem] bg-[var(--ht-lavender-light)] p-4 text-[var(--ht-night)]">
            <div class="flex flex-col justify-between gap-3 rounded-[1.5rem] bg-white p-4 sm:flex-row sm:items-center">
              <div><p class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--ht-indigo)]">Generated timestamp sandbox cards</p><p class="mt-1 text-sm text-[var(--ht-night-60)]"><span data-timestamp-sandbox-target="resultCount">0</span> active cards in the browser.</p></div>
              <p class="rounded-full bg-[var(--ht-seafoam-20)] px-4 py-2 text-sm font-medium text-[var(--ht-night)]" aria-live="polite" data-timestamp-sandbox-target="status">Sandbox ready.</p>
            </div>
            <div class="mt-4 max-h-[40rem] min-h-[24rem] overflow-y-auto rounded-[1.5rem] bg-white/70 p-3" aria-label="Generated timestamp sandbox cards">
              <div class="grid min-h-[21rem] place-items-center rounded-[1.25rem] border border-dashed border-[var(--ht-indigo-20)] bg-white p-6 text-center" data-timestamp-sandbox-target="emptyState">
                <div><p class="font-display text-2xl font-semibold tracking-[-0.03em]">Ready to generate timestamps</p><p class="mt-2 max-w-md text-sm leading-6 text-[var(--ht-night-60)]">Run a 10-card batch or add one custom timestamp. Generated cards will appear here and update locally through Stimulus.</p><div class="mt-5 grid grid-cols-3 gap-2 opacity-70"><span class="h-16 rounded-2xl bg-[var(--ht-seafoam)]"></span><span class="h-16 rounded-2xl bg-[var(--ht-banana)]"></span><span class="h-16 rounded-2xl bg-[var(--ht-blush)]"></span></div></div>
              </div>
              <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-3" data-timestamp-sandbox-target="list"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="install" class="mx-auto grid max-w-7xl gap-5 px-5 py-12 sm:px-6 lg:grid-cols-2 lg:px-8">
      <article class="rounded-[2rem] border-2 border-[var(--ht-night)] bg-white p-6 shadow-[8px_8px_0_var(--ht-night)] sm:p-8">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--ht-tiger)]">Step 1</p>
        <h2 class="font-display mt-3 text-3xl font-semibold tracking-[-0.035em]">Install and pin the npm package</h2>
        <p class="mt-4 max-w-prose leading-7 text-[var(--ht-night-60)]">
          This sample is an importmap Rails app, so it installs from npm, vendors the package ESM build, and pins the module for browser imports.
        </p>
        <pre class="mt-6 overflow-x-auto rounded-[1.25rem] bg-[var(--ht-night)] p-5 text-sm leading-6 text-[var(--ht-seafoam)]"><code>npm install ../relative-timestamp-element
cp node_modules/relative-timestamp-element/dist/index.js vendor/javascript/relative-timestamp-element.js
cp node_modules/relative-timestamp-element/dist/chunk-*.js vendor/javascript/

# config/importmap.rb
pin "relative-timestamp-element", to: "relative-timestamp-element.js"</code></pre>
      </article>

      <article id="stimulus" class="rounded-[2rem] border-2 border-[var(--ht-night)] bg-[var(--ht-banana)] p-6 shadow-[8px_8px_0_var(--ht-night)] sm:p-8">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--ht-indigo)]">Step 2</p>
        <h2 class="font-display mt-3 text-3xl font-semibold tracking-[-0.035em]">Wrap it with Stimulus lifecycle</h2>
        <p class="mt-4 max-w-prose leading-7 text-[var(--ht-night)]/75">
          Stimulus owns connection and disconnection, which makes the element safe with Turbo morphing, frame replacement, and dynamic DOM updates.
        </p>
        <pre class="mt-6 overflow-x-auto rounded-[1.25rem] border-2 border-[var(--ht-night)] bg-[var(--ht-night)] p-5 text-sm leading-6 text-[var(--ht-seafoam)] shadow-[6px_6px_0_var(--ht-indigo)]"><code>import { Controller } from "@hotwired/stimulus"
import { RelativeTimestamp } from "relative-timestamp-element"

export default class extends Controller {
  static values = {
    timestamp: String,
    locale: { type: String, default: "en" }
  }

  connect() {
    this.timestampController = new RelativeTimestamp(this.element, {
      locale: this.localeValue
    })
    this.timestampController.connect()
  }

  disconnect() {
    this.timestampController?.disconnect()
  }
}</code></pre>
      </article>
    </section>

    <section class="mx-auto grid max-w-7xl gap-5 px-5 py-8 sm:px-6 lg:grid-cols-2 lg:px-8">
      <article class="rounded-[2rem] bg-[var(--ht-seafoam)] p-6 sm:p-8">
        <h2 class="font-display text-3xl font-semibold tracking-[-0.035em]">Rails helper usage</h2>
        <p class="mt-4 leading-7 text-[var(--ht-night)]/75">The helper keeps ERB concise while preserving semantic fallback-first HTML.</p>
        <pre class="mt-6 overflow-x-auto rounded-[1.25rem] bg-white p-5 text-sm leading-6 text-[var(--ht-night)]"><code>&lt;%= relative_timestamp_tag(
  5.minutes.ago,
  fallback: "5 min",
  locale: "en"
) %&gt;

&lt;time
  data-controller="relative-timestamp"
  data-relative-timestamp-timestamp-value="..."
  data-relative-timestamp-locale-value="es"
  datetime="..."&gt;
  5 min
&lt;/time&gt;</code></pre>
      </article>

      <article class="rounded-[2rem] bg-[var(--ht-blush)] p-6 sm:p-8">
        <h2 class="font-display text-3xl font-semibold tracking-[-0.035em]">Refresh strategy</h2>
        <p class="mt-4 leading-7 text-[var(--ht-night)]/75">No global polling loop. Each timestamp schedules the next moment its visible label can change.</p>
        <ul class="mt-6 space-y-3 text-[var(--ht-night)]">
          <li class="rounded-2xl bg-white/80 p-4"><strong>Under 1 minute:</strong> second boundaries.</li>
          <li class="rounded-2xl bg-white/80 p-4"><strong>Under 1 hour:</strong> minute boundaries.</li>
          <li class="rounded-2xl bg-white/80 p-4"><strong>Under 1 day:</strong> hour boundaries.</li>
          <li class="rounded-2xl bg-white/80 p-4"><strong>Older:</strong> day boundaries.</li>
        </ul>
      </article>
    </section>

    <section class="mx-auto max-w-7xl px-5 py-8 pb-20 sm:px-6 lg:px-8">
      <div class="grid gap-5 lg:grid-cols-3">
        <article class="rounded-[2rem] bg-white p-7">
          <h3 class="font-display text-2xl font-semibold">API: RelativeTimestamp</h3>
          <p class="mt-3 leading-7 text-[var(--ht-night-60)]">Manual lifecycle wrapper with <code>connect()</code>, <code>disconnect()</code>, and <code>refresh()</code>.</p>
        </article>
